//Arduino IDE is a development platform used to write and upload code to Arduino boards, enabling communication between software and hardware components

#include <Servo.h>

// Servo objects
Servo servo1;
Servo servo2;
Servo servo3;
Servo servo4;
Servo servo5;

// Store angles (index 1–5)
int currentAngles[6] = {90, 90, 90, 90, 90, 90};

// Serial buffer
String input = "";

void setup() {
  Serial.begin(9600);

  servo1.attach(3);
  servo2.attach(5);
  servo3.attach(6);
  servo4.attach(9);
  servo5.attach(10);

  delay(1000); // Stabilize power

  // Set neutral positions
  for (int i = 1; i <= 5; i++) {
    moveServo(i, 90);
    delay(100);
  }

  Serial.println("ARM_READY");
}

// Move servo safely
void moveServo(int id, int angle) {
  angle = constrain(angle, 0, 180);
  currentAngles[id] = angle;

  switch (id) {
    case 1: servo1.write(angle); break;
    case 2: servo2.write(angle); break;
    case 3: servo3.write(angle); break;
    case 4: servo4.write(angle); break;
    case 5: servo5.write(angle); break;
  }
}

// Process serial command
void processCommand(String cmd) {
  cmd.trim();

  if (cmd.startsWith("S")) {
    int commaIdx = cmd.indexOf(',');

    if (commaIdx != -1) {
      int id = cmd.substring(1, commaIdx).toInt();
      int angle = cmd.substring(commaIdx + 1).toInt();

      if (id >= 1 && id <= 5) {
        moveServo(id, angle);

        Serial.print("OK:");
        Serial.print(id);
        Serial.print(",");
        Serial.println(angle);
      } else {
        Serial.println("ERR:INVALID_ID");
      }
    } else {
      Serial.println("ERR:BAD_FORMAT");
    }
  }

  else if (cmd == "RESET") {
    for (int i = 1; i <= 5; i++) {
      moveServo(i, 90);
      delay(100);
    }
    Serial.println("RESET_DONE");
  }

  else if (cmd == "STATUS") {
    Serial.print("ANGLES:");
    for (int i = 1; i <= 5; i++) {
      Serial.print(currentAngles[i]);
      if (i < 5) Serial.print(",");
    }
    Serial.println();
  }
}

void loop() {
  while (Serial.available()) {
    char c = Serial.read();

    if (c == '\n') {
      processCommand(input);
      input = ""; // clear buffer
    } else {
      input += c;
    }
  }
}
